# ============================================================
# Arkive AI — Environment Variables Template
# Copy to .env.dev / .env.staging / .env.prod and fill values
# NEVER commit real credentials to version control
# ============================================================

# --- Environment ---
ENVIRONMENT=dev  # dev | staging | prod

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
MONGO_DB_NAME=arkive_db  # arkive_db_dev | arkive_db_staging | arkive_db_prod

# --- Groq API ---
GROQ_API_KEY=gsk_...
# Production rate limits — handled defensively in code regardless of tier

# --- JWT ---
JWT_SECRET_KEY=<generate-256-bit-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- Redis ---
# Upstash (recommended): redis://default:<password>@<host>.upstash.io:6379
# Railway add-on: set automatically as REDIS_URL
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_TTL_CLASSIFICATION=3600   # 1 hour
REDIS_TTL_RAG=86400             # 24 hours

# --- CORS ---
# Comma-separated allowed origins. Use * only in local dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Stripe (Phase 4.1) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# --- Auth0 (Phase 4.2) ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...
AUTH0_AUDIENCE=https://api.arkiveai.com

# --- Logging ---
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOGTAIL_SOURCE_TOKEN=  # Optional: ship logs to BetterStack/Logtail

# --- File Limits ---
MAX_UPLOAD_SIZE_MB=100

# --- Report Storage ---
# local: store PDFs in filesystem (dev only)
# gridfs: store in MongoDB GridFS (staging/prod)
# s3: store in S3-compatible object storage (future)
REPORT_STORAGE=local
REPORT_RETENTION_DAYS=90

# --- Feature Flags ---
ENABLE_REDIS_CACHE=true
ENABLE_RERANKER=true
ENABLE_MULTI_FRAMEWORK=false  # Enable after Phase 3.2 ships
ENABLE_STRIPE=false           # Enable after Phase 4.1 ships
ENABLE_SSO=false              # Enable after Phase 4.2 ships
